# Keep generated-component source bytes stable after cloning on any platform.
# PowerShell runs these UTF-8/LF scripts normally on Windows.
*.ps1 text eol=lf
*.cmd text eol=crlf
*.vbs text eol=crlf

# Treat release and graphic assets as binary.
*.dll binary
*.png binary
*.zip binary
*.pcap binary
*.pcapng binary
