<Application x:Class="MuteCue.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#171A21" />
    <SolidColorBrush x:Key="PanelBrush" Color="#222733" />
    <SolidColorBrush x:Key="AccentBrush" Color="#6BA8FF" />
    <Style TargetType="TabItem">
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="Foreground" Value="#CDD6E6" />
      <Setter Property="Background" Value="#222733" />
    </Style>
  </Application.Resources>
</Application>
