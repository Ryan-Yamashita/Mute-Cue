<Window x:Class="MuteCue.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mute Cue Settings" Height="700" Width="500" ResizeMode="NoResize" Topmost="True"
        Icon="/Assets/mute-cue-tray.png"
        Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource ForegroundBrush}" WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1" Padding="22,12">
      <Grid>
        <Image Source="/Assets/mute-cue-logo-transparent.png" Width="150" Height="43" Stretch="Uniform" HorizontalAlignment="Left" />
        <Border x:Name="DevBadge" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center" Background="#392329" BorderBrush="#FF4352" BorderThickness="1" CornerRadius="4" Padding="9,4">
          <TextBlock Text="DEV" Foreground="#FF6A76" FontFamily="Segoe UI Semibold" FontSize="12" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="#16181D" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1" Padding="16,7">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
        <Button x:Name="DiscordTab" Grid.Column="0" Height="40" Margin="3,0" Padding="10,4" Click="DiscordTab_OnClick">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><Image Source="/Assets/discord-logo.png" Width="20" Height="20" Margin="0,0,7,0"/><TextBlock x:Name="DiscordTabLabel" Text="Discord" FontFamily="Segoe UI Semibold" FontSize="13"/></StackPanel>
        </Button>
        <Button x:Name="BeacnTab" Grid.Column="1" Height="40" Margin="3,0" Padding="10,4" Click="BeacnTab_OnClick">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><Image Source="/Assets/beacn-logo.png" Width="20" Height="20" Margin="0,0,7,0"/><TextBlock x:Name="BeacnTabLabel" Text="BEACN" FontFamily="Segoe UI Semibold" FontSize="13"/></StackPanel>
        </Button>
        <Button x:Name="SettingsTab" Grid.Column="2" Height="40" Margin="3,0" Padding="10,4" Click="SettingsTab_OnClick">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock x:Name="SettingsTabLabel" Text="Settings" FontFamily="Segoe UI Semibold" FontSize="13"/></StackPanel>
        </Button>
      </Grid>
    </Border>

    <Grid Grid.Row="2">
      <ScrollViewer x:Name="DiscordPage" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="22,14,22,14">
          <TextBlock Text="Connect Discord" FontSize="24" FontFamily="Segoe UI Semibold" Margin="0,8,0,8" />
          <Border Background="{StaticResource ControlBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="Discord monitoring" FontFamily="Segoe UI Semibold" />
              <TextBlock Text="Mute Cue reads Discord mute and deafen status only on this computer." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,0" />
            </StackPanel>
          </Border>
          <TextBlock x:Name="DiscordStatus" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8" />
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Connect Discord" Style="{StaticResource AccentButton}" Click="ConnectDiscord_OnClick" />
            <Button Content="Disconnect" Style="{StaticResource ActionButton}" Margin="8,0,0,0" Click="DisconnectDiscord_OnClick" />
            <Button Content="Forget authorization" Style="{StaticResource ActionButton}" Margin="8,0,0,0" Click="ForgetDiscord_OnClick" />
          </StackPanel>
          <Grid Height="38"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Microphone muted" FontSize="14" VerticalAlignment="Center"/><CheckBox x:Name="DiscordMicDetect" Grid.Column="1" Style="{StaticResource MuteCueToggle}" Checked="Setting_OnChanged" Unchecked="Setting_OnChanged"/></Grid>
          <Grid Height="38"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Deafened" FontSize="14" VerticalAlignment="Center"/><CheckBox x:Name="DiscordDeafenDetect" Grid.Column="1" Style="{StaticResource MuteCueToggle}" Checked="Setting_OnChanged" Unchecked="Setting_OnChanged"/></Grid>
          <TextBlock Text="NOTE: MUST BE IN A VOICE CHANNEL OR CALL FOR THE OVERLAY TO WORK" FontFamily="Segoe UI Semibold" Foreground="#EFC15A" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0" />
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="BeacnPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="22,14,22,14">
          <TextBlock Text="BEACN Monitoring" FontSize="24" FontFamily="Segoe UI Semibold" Margin="0,8,0,8" />
          <Border Background="#301F17" BorderBrush="#715723" BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,16">
            <StackPanel>
              <TextBlock Text="Native BEACN monitoring" Foreground="#EFC15A" FontFamily="Segoe UI Semibold" />
              <TextBlock Text="Mute Cue reads BEACN's active mute actions locally and refreshes an affected fader immediately after a desktop click." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,0" />
            </StackPanel>
          </Border>
          <TextBlock x:Name="BeacnStatus" Text="Discovering the BEACN mixer layout..." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12" />
          <TextBlock Text="Fader Sources" FontSize="18" FontFamily="Segoe UI Semibold" Margin="0,2,0,6" />
          <TextBlock Text="Choose which mute states should show the overlay for each mixer source." Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
          <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="92"/><ColumnDefinition Width="112"/></Grid.ColumnDefinitions><TextBlock Text="Source" Foreground="{StaticResource MutedBrush}" FontSize="12"/><TextBlock Grid.Column="1" Text="Mute to All" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Center"/><TextBlock Grid.Column="2" Text="Mute to Audience" Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Center"/></Grid>
          <Border Background="#1B1D22" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" Padding="8"><StackPanel x:Name="FaderSources"/></Border>
          <TextBlock Text="Selections are saved to the same Mute Cue settings file used by previous releases." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,12,0,0" />
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="22,14,22,14">
          <TextBlock Text="Overlay Settings" FontSize="24" FontFamily="Segoe UI Semibold" Margin="0,8,0,12" />
          <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Overlay size" FontSize="14"/><TextBlock x:Name="OverlaySizeValue" Grid.Column="1" Foreground="{StaticResource MutedBrush}" FontFamily="Segoe UI Semibold" FontSize="12"/></Grid>
          <Slider x:Name="OverlaySize" Minimum="220" Maximum="900" TickFrequency="10" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,12" ValueChanged="OverlaySize_OnValueChanged" />
          <Grid Margin="0,2,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Opacity" FontSize="14"/><TextBlock x:Name="OverlayOpacityValue" Grid.Column="1" Foreground="{StaticResource MutedBrush}" FontFamily="Segoe UI Semibold" FontSize="12"/></Grid>
          <Slider x:Name="OverlayOpacity" Minimum="0.25" Maximum="1" TickFrequency="0.05" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,14" ValueChanged="OverlayOpacity_OnValueChanged" />
          <Grid Height="38"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Click through overlay" FontSize="14" VerticalAlignment="Center"/><CheckBox x:Name="ClickThrough" Grid.Column="1" Style="{StaticResource MuteCueToggle}" Checked="Setting_OnChanged" Unchecked="Setting_OnChanged"/></Grid>
          <Grid Height="38"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Close to system tray" FontSize="14" VerticalAlignment="Center"/><CheckBox x:Name="CloseToTray" Grid.Column="1" Style="{StaticResource MuteCueToggle}" Checked="Setting_OnChanged" Unchecked="Setting_OnChanged"/></Grid>
          <Grid Height="38"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="RunOnStartupLabel" Text="Run on startup" FontSize="14" VerticalAlignment="Center"/><CheckBox x:Name="RunOnStartup" Grid.Column="1" Style="{StaticResource MuteCueToggle}" Checked="RunOnStartup_OnChanged" Unchecked="RunOnStartup_OnChanged"/></Grid>
          <Grid Height="38" Margin="20,0,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Start in system tray" FontSize="14" VerticalAlignment="Center"/><CheckBox x:Name="StartInTray" Grid.Column="1" Style="{StaticResource MuteCueToggle}" Checked="Setting_OnChanged" Unchecked="Setting_OnChanged"/></Grid>
          <TextBlock Text="Overlay check" FontSize="18" FontFamily="Segoe UI Semibold" Margin="0,18,0,5" />
          <TextBlock Text="Show the overlay for six seconds, or center it if it was saved on a disconnected monitor." Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,9" />
          <StackPanel Orientation="Horizontal">
            <Button Content="Preview Overlay" Style="{StaticResource ActionButton}" Click="PreviewOverlay_OnClick" />
            <Button Content="Center and Preview" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Click="CenterOverlay_OnClick" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <Border Grid.Row="3" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0" Padding="22,12">
      <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="Save Settings" Style="{StaticResource ActionButton}" Click="Save_OnClick"/><Button Content="Close" Style="{StaticResource AccentButton}" Margin="8,0,0,0" Click="Close_OnClick"/></StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
